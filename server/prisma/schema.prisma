
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// Standard JS Prisma Client runtime (required for running standalone Node scripts in containers)
generator client_js {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
  APPLE
}


enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  /// New (spec): payment succeeded
  PAID
  /// Legacy (kept for backward compatibility; treat as PAID in code)
  SUCCESS
  FAILED
  /// New (spec): payment link expired
  EXPIRED
  REFUNDED
}

enum PaymentTransactionStatus {
  PENDING
  PAID
  FAILED
  /// New (spec): payment link expired
  EXPIRED
}

enum InventoryAction {
  IMPORT
  EXPORT
  RETURN
  ADJUSTMENT
}

enum ActorType {
  ADMIN
  USER
  SYSTEM
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum ReturnFlowStatus {
  /// Buyer yeu cau tra hang (cho duyet)
  REQUESTED
  /// New (spec): admin da duyet yeu cau tra hang
  APPROVED
  /// Da duoc duyet, cho shipper den lay
  WAITING_PICKUP
  /// New (spec): hang dang duoc gui tra ve
  SHIPPING
  /// Shipper da lay hang, dang tra ve shop
  RETURNING
  /// Shop da nhan hang tra (ket thuc)
  COMPLETED
  /// Yeu cau tra hang bi tu choi (ket thuc)
  REJECTED
}

enum RefundType {
  CANCEL_REFUND
  RETURN_REFUND
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

enum CancelReason {
  NO_LONGER_NEEDED
  BUY_OTHER_ITEM
  FOUND_CHEAPER
  OTHER
}

enum CancelRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum DiscountType {
  PERCENTAGE   // Giảm theo %
  FIXED_AMOUNT // Giảm số tiền cố định
}

// ============================================================================
// LONG-TERM CATALOG (ProductType + Attribute System)
// (Additive: designed to coexist with current Product/ProductVariant JSON attrs)
// ============================================================================

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum VariantStatus {
  ACTIVE
  INACTIVE
}

enum AttributeScope {
  PRODUCT
  VARIANT
}

enum AttributeDataType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
  MULTI_SELECT
}

// ============================================================================
// AUTHENTICATION
// ============================================================================

/// Bảng người dùng gốc - lưu thông tin xác thực cốt lõi
model User {
  id            String     @id @default(uuid()) @db.VarChar(36)
  email         String?    @unique @db.VarChar(255)
  phone         String?    @unique @db.VarChar(20)
  passwordHash  String?    @map("password_hash") @db.VarChar(255)
  emailVerified Boolean    @default(false) @map("email_verified")
  phoneVerified Boolean    @default(false) @map("phone_verified")
  status        UserStatus @default(ACTIVE)
  lastLogin     DateTime?  @map("last_login")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  addresses                  UserAddress[]
  refreshTokens              RefreshToken[]
  oauthAccounts              OAuthAccount[]
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  userRoles                  UserRole[]
  cart                       Cart?
  orders                     Order[]
  notifications              Notification[]
  activityLogs               UserActivityLog[]
  wishlist                   Wishlist[]
  reviews                    Review[]

  @@map("users")
}

/// Quản lý phiên đăng nhập với JWT
model RefreshToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  token      String   @unique @db.VarChar(500)
  deviceInfo String?  @map("device_info") @db.VarChar(500)
  expiresAt  DateTime @map("expires_at")
  revoked    Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// OTP cho xác minh email (đăng ký/đăng nhập)
model Otp {
  id           String   @id @default(uuid()) @db.VarChar(36)
  email        String   @unique @db.VarChar(255)
  otp          String   @db.VarChar(20)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  expiresAt    DateTime @map("expires_at")
  attempts     Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("otps")
}

/// Email verification tokens for registration flow
model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

/// Password reset tokens for forgot-password flow
model PasswordResetToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Liên kết đăng nhập OAuth (Google, Facebook, Apple)
model OAuthAccount {
  id             String        @id @default(uuid()) @db.VarChar(36)
  userId         String        @map("user_id") @db.VarChar(36)
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ============================================================================
// AUTHORIZATION (RBAC)
// ============================================================================

/// Định nghĩa các vai trò trong hệ thống
model Role {
  id   Int    @id @default(autoincrement())
  code String @unique @db.VarChar(50) // BUYER, SELLER, ADMIN
  name String @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userRoles UserRole[]

  @@map("roles")
}

/// Bảng trung gian - gán vai trò cho user (n-n)
model UserRole {
  userId     String   @map("user_id") @db.VarChar(36)
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ============================================================================
// PROFILE
// ============================================================================

/// Địa chỉ người dùng - quản lý nhiều địa chỉ giao hàng
model UserAddress {
  id          String  @id @default(uuid()) @db.VarChar(36)
  userId      String  @map("user_id") @db.VarChar(36)
  recipient   String  @db.VarChar(255)
  phone       String  @db.VarChar(20)
  addressLine String  @map("address_line") @db.Text
  ward        String  @db.VarChar(100)
  district    String  @db.VarChar(100)
  city        String  @db.VarChar(100)
  isDefault   Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_addresses")
}

// ============================================================================
// PRODUCTS (Soft delete + variants + images + categories)
// ============================================================================

/// Sản phẩm - thông tin cơ bản; tồn kho & giá thực tế nằm ở ProductVariant
model Product {
  id          String  @id @default(uuid()) @db.VarChar(36)
  /// Loại sản phẩm (áo/quần/phụ kiện...). Nullable để migrate dần.
  productTypeId String? @map("product_type_id") @db.VarChar(36)
  name        String  @db.VarChar(255)
  description String? @db.Text
  /// Giá hiển thị / khởi điểm; giá bán thực tế lấy từ ProductVariant.price
  basePrice   Decimal @map("base_price") @db.Decimal(10, 2)
  /// Trạng thái catalog (đi đường dài). Migrate dần, mặc định ACTIVE.
  status      ProductStatus @default(ACTIVE)
  /// Cache min/max price (không phải source of truth)
  minPrice    Decimal? @map("min_price") @db.Decimal(10, 2)
  maxPrice    Decimal? @map("max_price") @db.Decimal(10, 2)
  isNew       Boolean @default(false) @map("is_new")
  isSale      Boolean @default(false) @map("is_sale")
  isDeleted   Boolean @default(false) @map("is_deleted")
  /// Soft-delete chuẩn (nullable để migrate dần).
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  productType      ProductType?          @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  variants         ProductVariant[]
  images           ProductImage[]
  categories       ProductCategory[]
  tags             ProductTag[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  wishlist         Wishlist[]
  reviews          Review[]
  priceHistory     ProductPriceHistory[]
  campaignProducts CampaignProduct[]

  attributeValues  ProductAttributeValue[]

  @@fulltext([name])
  @@index([createdAt])
  @@index([productTypeId, status])
  @@index([deletedAt])
  @@map("products")
}

// ============================================================================
// PRODUCT VARIANTS & IMAGES
// ============================================================================

/// Biến thể sản phẩm - quản lý SKU, size/màu, tồn kho
model ProductVariant {
  id             String  @id @default(uuid()) @db.VarChar(36)
  productId      String  @map("product_id") @db.VarChar(36)
  sku            String  @unique @db.VarChar(100)
  /// Canonical key cho tổ hợp biến thể (vd: color=red|size=m). Nullable để backfill dần.
  optionKey      String? @map("option_key") @db.VarChar(500)
  status         VariantStatus @default(ACTIVE)
  isDefault      Boolean @default(false) @map("is_default")
  /// Thuộc tính biến thể: {"color": "đỏ", "size": "M"}
  attributes     Json    @default("{}")
  price          Decimal @db.Decimal(10, 2)
  stockAvailable Int     @default(0) @map("stock_available")
  /// Chuẩn dài hạn: stockOnHand (giữ song song để migrate)
  stockOnHand    Int     @default(0) @map("stock_on_hand")
  stockReserved  Int     @default(0) @map("stock_reserved")
  minStock       Int     @default(5) @map("min_stock")
  isDeleted      Boolean @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  images        ProductImage[]
  inventoryLogs InventoryLog[]
  priceHistory  ProductPriceHistory[]

  attributeValues VariantAttributeValue[]

  @@index([productId])
  @@index([productId, status])
  @@index([deletedAt])
  @@unique([productId, optionKey])
  @@map("product_variants")
}

/// Ảnh sản phẩm - ảnh chung hoặc riêng cho từng variant
model ProductImage {
  id        String  @id @default(uuid()) @db.VarChar(36)
  productId String  @map("product_id") @db.VarChar(36)
  variantId String? @map("variant_id") @db.VarChar(36)
  url       String  @db.VarChar(1000)
  altText   String? @map("alt_text") @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("product_images")
}

// ============================================================================
// CATEGORIES & TAGS
// ============================================================================

model Category {
  id          String  @id @default(uuid()) @db.VarChar(36)
  name        String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(255)
  description String? @db.Text
  imageUrl    String? @map("image_url") @db.VarChar(1000)
  sortOrder   Int     @default(0) @map("sort_order")

  parentId String? @map("parent_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  products ProductCategory[]
  @@index([parentId])
  @@index([deletedAt])
  @@map("categories")
}

/// Bảng trung gian - sản phẩm thuộc nhiều danh mục
model ProductCategory {
  productId  String @map("product_id") @db.VarChar(36)
  categoryId String @map("category_id") @db.VarChar(36)

  /// Merchandising
  isPrimary  Boolean @default(false) @map("is_primary")
  sortOrder  Int     @default(0) @map("sort_order")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, isPrimary, sortOrder])
  @@map("product_categories")
}

// ============================================================================
// PRODUCT TYPE
// ============================================================================

model ProductType {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products   Product[]
  attributes ProductTypeAttribute[]

  @@index([deletedAt])
  @@map("product_types")
}

// ============================================================================
// ATTRIBUTE DEFINITIONS
// ============================================================================

model AttributeDefinition {
  id        String           @id @default(uuid()) @db.VarChar(36)
  code      String           @unique @db.VarChar(100)
  name      String           @db.VarChar(255)
  scope     AttributeScope
  dataType  AttributeDataType @map("data_type")
  unit      String?          @db.VarChar(50)

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  options   AttributeOption[]
  typeMaps  ProductTypeAttribute[]
  productValues ProductAttributeValue[]
  variantValues VariantAttributeValue[]

  @@index([scope, dataType])
  @@index([deletedAt])
  @@map("attribute_definitions")
}

model AttributeOption {
  id          String   @id @default(uuid()) @db.VarChar(36)
  attributeId String   @map("attribute_id") @db.VarChar(36)
  value       String   @db.VarChar(100)
  label       String   @db.VarChar(255)
  sortOrder   Int      @default(0) @map("sort_order")
  swatchHex   String?  @map("swatch_hex") @db.VarChar(16)

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attribute AttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  productValues ProductAttributeValue[]
  productMultiSelectJoins ProductAttributeValueOption[]
  variantValues VariantAttributeValue[]
  variantMultiSelectJoins VariantAttributeValueOption[]

  @@unique([attributeId, value])
  @@index([attributeId, sortOrder])
  @@index([deletedAt])
  @@map("attribute_options")
}

model ProductTypeAttribute {
  productTypeId String @map("product_type_id") @db.VarChar(36)
  attributeId   String @map("attribute_id") @db.VarChar(36)

  isRequired    Boolean @default(false) @map("is_required")
  isFilterable  Boolean @default(false) @map("is_filterable")
  isVariantAxis Boolean @default(false) @map("is_variant_axis")
  variantAxisOrder Int? @map("variant_axis_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productType ProductType         @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  attribute   AttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([productTypeId, attributeId])
  @@index([productTypeId, isVariantAxis, variantAxisOrder])
  @@map("product_type_attributes")
}

// ============================================================================
// ATTRIBUTE VALUES (PRODUCT)
// ============================================================================

model ProductAttributeValue {
  id          String   @id @default(uuid()) @db.VarChar(36)
  productId   String   @map("product_id") @db.VarChar(36)
  attributeId String   @map("attribute_id") @db.VarChar(36)

  textValue    String?  @map("text_value") @db.Text
  numberValue  Decimal? @map("number_value") @db.Decimal(18, 4)
  booleanValue Boolean? @map("boolean_value")
  dateValue    DateTime? @map("date_value")
  optionId     String?  @map("option_id") @db.VarChar(36)

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute AttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  option    AttributeOption?    @relation(fields: [optionId], references: [id], onDelete: SetNull)

  multiSelectOptions ProductAttributeValueOption[]

  @@unique([productId, attributeId])
  @@index([attributeId, optionId])
  @@index([deletedAt])
  @@map("product_attribute_values")
}

model ProductAttributeValueOption {
  productAttributeValueId String @map("product_attribute_value_id") @db.VarChar(36)
  optionId                String @map("option_id") @db.VarChar(36)

  value  ProductAttributeValue @relation(fields: [productAttributeValueId], references: [id], onDelete: Cascade)
  option AttributeOption       @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([productAttributeValueId, optionId])
  @@index([optionId])
  @@map("product_attribute_value_options")
}

// ============================================================================
// ATTRIBUTE VALUES (VARIANT)
// ============================================================================

model VariantAttributeValue {
  id          String   @id @default(uuid()) @db.VarChar(36)
  variantId   String   @map("variant_id") @db.VarChar(36)
  attributeId String   @map("attribute_id") @db.VarChar(36)

  textValue    String?  @map("text_value") @db.Text
  numberValue  Decimal? @map("number_value") @db.Decimal(18, 4)
  booleanValue Boolean? @map("boolean_value")
  dateValue    DateTime? @map("date_value")
  optionId     String?  @map("option_id") @db.VarChar(36)

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  variant   ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute AttributeDefinition  @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  option    AttributeOption?     @relation(fields: [optionId], references: [id], onDelete: SetNull)

  multiSelectOptions VariantAttributeValueOption[]

  @@unique([variantId, attributeId])
  @@index([attributeId, optionId])
  @@index([deletedAt])
  @@map("variant_attribute_values")
}

model VariantAttributeValueOption {
  variantAttributeValueId String @map("variant_attribute_value_id") @db.VarChar(36)
  optionId                String @map("option_id") @db.VarChar(36)

  value  VariantAttributeValue @relation(fields: [variantAttributeValueId], references: [id], onDelete: Cascade)
  option AttributeOption       @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([variantAttributeValueId, optionId])
  @@index([optionId])
  @@map("variant_attribute_value_options")
}

/// Tag - nhãn tự do gắn vào sản phẩm
model Tag {
  id   String @id @default(uuid()) @db.VarChar(36)
  name String @unique @db.VarChar(100)
  slug String @unique @db.VarChar(100)

  products ProductTag[]

  @@map("tags")
}

/// Bảng trung gian - sản phẩm gắn nhiều tag
model ProductTag {
  productId String @map("product_id") @db.VarChar(36)
  tagId     String @map("tag_id") @db.VarChar(36)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

// ============================================================================
// CART
// ============================================================================

/// Giỏ hàng - mỗi user có 1 giỏ hàng
model Cart {
  id     String @id @default(uuid()) @db.VarChar(36)
  userId String @unique @map("user_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

/// Chi tiết giỏ hàng
model CartItem {
  id        String  @id @default(uuid()) @db.VarChar(36)
  cartId    String  @map("cart_id") @db.VarChar(36)
  productId String  @map("product_id") @db.VarChar(36)
  variantId String? @map("variant_id") @db.VarChar(36)
  quantity  Int

  // Relations
  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  /// Nếu variantId IS NULL, MySQL cho phép trùng (cartId, productId, NULL) → app phải enforce
  @@unique([cartId, productId, variantId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

// ============================================================================
// ORDERS
// ============================================================================

/// Đơn hàng
model Order {
  id             String      @id @default(uuid()) @db.VarChar(36)
  userId         String      @map("user_id") @db.VarChar(36)
  totalPrice     Decimal     @map("total_price") @db.Decimal(10, 2)
  status         OrderStatus @default(PENDING)
  returnStatus   ReturnFlowStatus? @map("return_status")
  discountId     String?     @map("discount_id") @db.VarChar(36)
  discountAmount Decimal?    @map("discount_amount") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user          User                 @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payment       Payment?
  paymentTransaction PaymentTransaction?
  refundTransactions RefundTransaction[]
  cancelRequest OrderCancelRequest?
  statusHistory OrderStatusHistory[]
  invoice       Invoice?
  discount      Discount?            @relation(fields: [discountId], references: [id])
  discountUsage DiscountUsage?

  @@index([status])
  @@index([userId])
  @@map("orders")
}

/// Chi tiết đơn hàng
model OrderItem {
  id        String  @id @default(uuid()) @db.VarChar(36)
  orderId   String  @map("order_id") @db.VarChar(36)
  productId String  @map("product_id") @db.VarChar(36)
  variantId String? @map("variant_id") @db.VarChar(36)
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  // Relations
  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  returns Return[]
  reviews Review[] @relation("OrderItemReviews")

  @@unique([orderId, productId, variantId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

// ============================================================================
// PAYMENT (1 order = 1 payment chính)
// ============================================================================

/// Thanh toán - 1:1 với đơn hàng
model Payment {
  id            String        @id @default(uuid()) @db.VarChar(36)
  orderId       String        @unique @map("order_id") @db.VarChar(36)
  amount        Decimal       @db.Decimal(10, 2)
  method        String        @db.VarChar(50)
  transactionId String?       @unique @map("transaction_id") @db.VarChar(255)
  status        PaymentStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at")
  paidAt    DateTime? @map("paid_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

/// Giao dịch thanh toan online (idempotent qua trang thai PENDING)
model PaymentTransaction {
  id                   String                   @id @default(uuid()) @db.VarChar(36)
  orderId               String                   @unique @map("order_id") @db.VarChar(36)
  orderCode             String                   @unique @map("order_code") @db.VarChar(64)
  amount                Decimal                  @db.Decimal(10, 2)
  status                PaymentTransactionStatus @default(PENDING)
  bankCode              String?                  @map("bank_code") @db.VarChar(20)
  gatewayReference      String?                  @unique @map("vnp_transaction_no") @db.VarChar(64)
  gatewayCode           String?                  @map("vnp_response_code") @db.VarChar(10)
  gatewayStatus         String?                  @map("vnp_transaction_status") @db.VarChar(10)
  paidAt                DateTime?                @map("paid_at")
  rawPayload            Json?                    @map("raw_payload")

  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([orderCode])
  @@map("payment_transactions")
}

// ============================================================================
// PRICING HISTORY
// ============================================================================

/// Lịch sử thay đổi giá - phục vụ analytics và audit
model ProductPriceHistory {
  id        String   @id @default(uuid()) @db.VarChar(36)
  productId String   @map("product_id") @db.VarChar(36)
  variantId String?  @map("variant_id") @db.VarChar(36)
  oldPrice  Decimal  @map("old_price") @db.Decimal(10, 2)
  newPrice  Decimal  @map("new_price") @db.Decimal(10, 2)
  changedBy String?  @map("changed_by") @db.VarChar(36)

  changedAt DateTime @default(now()) @map("changed_at")

  // Relations
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@map("product_price_history")
}

// ============================================================================
// PROMOTIONS
// ============================================================================

/// Mã giảm giá
model Discount {
  id             String       @id @default(uuid()) @db.VarChar(36)
  code           String       @unique @db.VarChar(50)
  description    String?      @db.VarChar(500)
  type           DiscountType
  value          Decimal      @db.Decimal(10, 2)
  maxDiscount    Decimal?     @map("max_discount") @db.Decimal(10, 2)
  minOrderAmount Decimal?     @map("min_order_amount") @db.Decimal(10, 2)
  maxUsage       Int?         @map("max_usage")
  userUsageLimit Int?         @map("user_usage_limit")
  usedCount      Int          @default(0) @map("used_count")
  startAt        DateTime     @map("start_at")
  endAt          DateTime     @map("end_at")
  isActive       Boolean      @default(true) @map("is_active")
  bannerImageUrl String?      @map("banner_image_url") @db.VarChar(1000)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  usages    DiscountUsage[]
  campaigns CampaignDiscount[]
  orders    Order[]

  @@index([isActive, startAt, endAt])
  @@map("discounts")
}

model Banner {
  id          String  @id @default(uuid()) @db.VarChar(36)
  title       String  @db.VarChar(255)
  subtitle    String? @db.VarChar(255)
  description String? @db.VarChar(500)
  imageUrl    String  @map("image_url") @db.VarChar(1000)
  isActive    Boolean @default(false) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("banners")
}

/// Lịch sử sử dụng mã giảm giá
model DiscountUsage {
  id         String   @id @default(uuid()) @db.VarChar(36)
  discountId String   @map("discount_id") @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  orderId    String   @unique @map("order_id") @db.VarChar(36)

  usedAt DateTime @default(now()) @map("used_at")

  // Relations
  discount Discount @relation(fields: [discountId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([discountId])
  @@index([userId])
  @@map("discount_usages")
}

/// Chiến dịch khuyến mãi - nhóm sản phẩm giảm giá theo thời gian
model Campaign {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  isActive    Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  products  CampaignProduct[]
  discounts CampaignDiscount[]

  @@map("campaigns")
}

/// Sản phẩm tham gia chiến dịch khuyến mãi
model CampaignProduct {
  campaignId      String  @map("campaign_id") @db.VarChar(36)
  productId       String  @map("product_id") @db.VarChar(36)
  /// % giảm riêng cho sản phẩm trong chiến dịch (0.00 - 100.00)
  discountPercent Decimal @map("discount_percent") @db.Decimal(5, 2)

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([campaignId, productId])
  @@map("campaign_products")
}

/// Mã giảm giá áp dụng trong chiến dịch
model CampaignDiscount {
  campaignId String @map("campaign_id") @db.VarChar(36)
  discountId String @map("discount_id") @db.VarChar(36)

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@id([campaignId, discountId])
  @@map("campaign_discounts")
}

// ============================================================================
// INVENTORY LOG (Audit kho hàng)
// ============================================================================

/// Lịch sử nhập/xuất kho - theo dõi ở cấpđộ variant
model InventoryLog {
  id          String          @id @default(uuid()) @db.VarChar(36)
  variantId   String          @map("variant_id") @db.VarChar(36)
  action      InventoryAction
  quantity    Int
  referenceId String?         @map("reference_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId])
  @@map("inventory_logs")
}

// ============================================================================
// RETURNS (Đúng cấp order_item)
// ============================================================================

/// Yêu cầu trả hàng - liên kết với từng order_item
model Return {
  id          String       @id @default(uuid()) @db.VarChar(36)
  orderItemId String       @map("order_item_id") @db.VarChar(36)
  quantity    Int
  reason      String?      @db.Text
  status      ReturnStatus @default(REQUESTED)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([orderItemId])
  @@map("returns")
}

// ============================================================================
// ORDER STATUS HISTORY
// ============================================================================

/// Lịch sử thay đổi trạng thái đơn hàng
model OrderStatusHistory {
  id        String       @id @default(uuid()) @db.VarChar(36)
  orderId   String       @map("order_id") @db.VarChar(36)
  oldStatus OrderStatus? @map("old_status")
  newStatus OrderStatus  @map("new_status")
  changedBy String?      @map("changed_by") @db.VarChar(36)

  changedAt DateTime @default(now()) @map("changed_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

/// Thông báo cho người dùng
model Notification {
  id      String  @id @default(uuid()) @db.VarChar(36)
  userId  String  @map("user_id") @db.VarChar(36)
  content String  @db.Text
  isRead  Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// ============================================================================
// USER ACTIVITY LOG (Phân tích hành vi)
// ============================================================================

/// Lịch sử hoạt động người dùng - phục vụ phân tích AI
model UserActivityLog {
  id       String  @id @default(uuid()) @db.VarChar(36)
  userId   String? @map("user_id") @db.VarChar(36)
  action   String  @db.VarChar(255)
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_activity_logs")
}

// ============================================================================
// WISHLIST
// ============================================================================

/// Danh sách yêu thích
model Wishlist {
  id        String @id @default(uuid()) @db.VarChar(36)
  userId    String @map("user_id") @db.VarChar(36)
  productId String @map("product_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@map("wishlists")
}

// ============================================================================
// REVIEWS
// ============================================================================

/// Đánh giá sản phẩm - mỗi user chỉ đánh giá 1 lần/sản phẩm
model Review {
  id        String  @id @default(uuid()) @db.VarChar(36)
  userId    String  @map("user_id") @db.VarChar(36)
  productId String  @map("product_id") @db.VarChar(36)
  orderItemId String? @map("order_item_id") @db.VarChar(36)
  rating    Int // 1-5
  comment   String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  orderItem OrderItem? @relation("OrderItemReviews", fields: [orderItemId], references: [id], onDelete: Cascade)
  images   ReviewImage[]

  @@unique([userId, orderItemId])
  @@index([productId])
  @@index([orderItemId])
  @@map("reviews")
}

model ReviewImage {
  id       String @id @default(uuid()) @db.VarChar(36)
  reviewId String @map("review_id") @db.VarChar(36)
  url      String @db.VarChar(1000)
  publicId String? @map("public_id") @db.VarChar(255)
  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_images")
}

// ============================================================================
// INVOICES
// ============================================================================

/// Hóa đơn - 1:1 với đơn hàng
model Invoice {
  id            String  @id @default(uuid()) @db.VarChar(36)
  orderId       String  @unique @map("order_id") @db.VarChar(36)
  invoiceNumber String  @unique @map("invoice_number") @db.VarChar(50)
  totalAmount   Decimal @map("total_amount") @db.Decimal(10, 2)

  issuedAt DateTime @default(now()) @map("issued_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id])

  @@map("invoices")
}

// ============================================================================
// AUDIT LOG (Chuẩn compliance)
// ============================================================================

/// Nhật ký kiểm toán - theo dõi mọi thay đổi trong hệ thống
model AuditLog {
  id         String    @id @default(uuid()) @db.VarChar(36)
  actorType  ActorType @map("actor_type")
  actorId    String?   @map("actor_id") @db.VarChar(36)
  targetType String?   @map("target_type") @db.VarChar(100)
  targetId   String?   @map("target_id") @db.VarChar(36)
  action     String    @db.VarChar(255)
  oldData    Json?     @map("old_data")
  newData    Json?     @map("new_data")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@map("audit_logs")
}

model RefundTransaction {
  id               String       @id @default(uuid()) @db.VarChar(36)
  orderId          String       @map("order_id") @db.VarChar(36)
  type             RefundType
  amount           Decimal      @db.Decimal(10, 2)
  currency         String       @default("VND") @db.VarChar(10)
  status           RefundStatus @default(PENDING)
  provider         String?      @db.VarChar(50)
  providerRefundId String?      @unique @map("provider_refund_id") @db.VarChar(100)
  reason           String?      @db.Text
  initiatedBy      ActorType    @default(SYSTEM) @map("initiated_by")
  idempotencyKey   String       @unique @map("idempotency_key") @db.VarChar(120)
  failureReason    String?      @map("failure_reason") @db.VarChar(500)
  retryCount       Int          @default(0) @map("retry_count")
  requestedAt      DateTime     @default(now()) @map("requested_at")
  processedAt      DateTime?    @map("processed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, type])
  @@index([orderId])
  @@index([status])
  @@index([type])
  @@map("refund_transactions")
}

model OrderCancelRequest {
  id                String              @id @default(uuid()) @db.VarChar(36)
  orderId           String              @unique @map("order_id") @db.VarChar(36)
  reasonCode        CancelReason        @map("reason_code")
  reasonText        String?             @map("reason_text") @db.VarChar(500)
  status            CancelRequestStatus @default(REQUESTED)
  requestedByUserId String              @map("requested_by_user_id") @db.VarChar(36)
  approvedByAdminId String?             @map("approved_by_admin_id") @db.VarChar(36)
  rejectedByAdminId String?             @map("rejected_by_admin_id") @db.VarChar(36)
  approvedAt        DateTime?           @map("approved_at")
  rejectedAt        DateTime?           @map("rejected_at")
  completedAt       DateTime?           @map("completed_at")
  rejectionReason   String?             @map("rejection_reason") @db.VarChar(500)

  bankAccountName   String              @map("bank_account_name") @db.VarChar(255)
  bankAccountNumber String              @map("bank_account_number") @db.VarChar(50)
  bankName          String              @map("bank_name") @db.VarChar(120)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([requestedByUserId])
  @@map("order_cancel_requests")
}