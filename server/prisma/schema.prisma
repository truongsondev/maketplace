
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
  APPLE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum InventoryAction {
  IMPORT
  EXPORT
  RETURN
  ADJUSTMENT
}

enum ActorType {
  ADMIN
  USER
  SYSTEM
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum DiscountType {
  PERCENTAGE   // Giảm theo %
  FIXED_AMOUNT // Giảm số tiền cố định
}

// ============================================================================
// AUTHENTICATION
// ============================================================================

/// Bảng người dùng gốc - lưu thông tin xác thực cốt lõi
model User {
  id            String     @id @default(uuid()) @db.VarChar(36)
  email         String?    @unique @db.VarChar(255)
  phone         String?    @unique @db.VarChar(20)
  passwordHash  String?    @map("password_hash") @db.VarChar(255)
  emailVerified Boolean    @default(false) @map("email_verified")
  phoneVerified Boolean    @default(false) @map("phone_verified")
  status        UserStatus @default(ACTIVE)
  lastLogin     DateTime?  @map("last_login")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  profile                    UserProfile?
  addresses                  UserAddress[]
  refreshTokens              RefreshToken[]
  oauthAccounts              OAuthAccount[]
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  userRoles                  UserRole[]
  cart                       Cart?
  orders                     Order[]
  notifications              Notification[]
  activityLogs               UserActivityLog[]
  wishlist                   Wishlist[]
  reviews                    Review[]

  @@map("users")
}

/// Quản lý phiên đăng nhập với JWT
model RefreshToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  token      String   @unique @db.VarChar(500)
  deviceInfo String?  @map("device_info") @db.VarChar(500)
  expiresAt  DateTime @map("expires_at")
  revoked    Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// OTP cho xác minh email (đăng ký/đăng nhập)
model Otp {
  id           String   @id @default(uuid()) @db.VarChar(36)
  email        String   @unique @db.VarChar(255)
  otp          String   @db.VarChar(20)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  expiresAt    DateTime @map("expires_at")
  attempts     Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("otps")
}

/// Email verification tokens for registration flow
model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

/// Password reset tokens for forgot-password flow
model PasswordResetToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Liên kết đăng nhập OAuth (Google, Facebook, Apple)
model OAuthAccount {
  id             String        @id @default(uuid()) @db.VarChar(36)
  userId         String        @map("user_id") @db.VarChar(36)
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ============================================================================
// AUTHORIZATION (RBAC)
// ============================================================================

/// Định nghĩa các vai trò trong hệ thống
model Role {
  id   Int    @id @default(autoincrement())
  code String @unique @db.VarChar(50) // BUYER, SELLER, ADMIN
  name String @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userRoles UserRole[]

  @@map("roles")
}

/// Bảng trung gian - gán vai trò cho user (n-n)
model UserRole {
  userId     String   @map("user_id") @db.VarChar(36)
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ============================================================================
// PROFILE
// ============================================================================

/// Hồ sơ cá nhân - tách khỏi auth để dễ mở rộng
model UserProfile {
  userId    String    @id @map("user_id") @db.VarChar(36)
  fullName  String?   @map("full_name") @db.VarChar(255)
  avatarUrl String?   @map("avatar_url") @db.Text
  gender    Gender?
  birthday  DateTime? @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// Địa chỉ người dùng - quản lý nhiều địa chỉ giao hàng
model UserAddress {
  id          String  @id @default(uuid()) @db.VarChar(36)
  userId      String  @map("user_id") @db.VarChar(36)
  recipient   String  @db.VarChar(255)
  phone       String  @db.VarChar(20)
  addressLine String  @map("address_line") @db.Text
  ward        String  @db.VarChar(100)
  district    String  @db.VarChar(100)
  city        String  @db.VarChar(100)
  isDefault   Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_addresses")
}

// ============================================================================
// PRODUCTS (Soft delete + variants + images + categories)
// ============================================================================

/// Sản phẩm - thông tin cơ bản; tồn kho & giá thực tế nằm ở ProductVariant
model Product {
  id          String  @id @default(uuid()) @db.VarChar(36)
  name        String  @db.VarChar(255)
  description String? @db.Text
  /// Giá hiển thị / khởi điểm; giá bán thực tế lấy từ ProductVariant.price
  basePrice   Decimal @map("base_price") @db.Decimal(10, 2)
  isDeleted   Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  variants         ProductVariant[]
  images           ProductImage[]
  categories       ProductCategory[]
  tags             ProductTag[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  wishlist         Wishlist[]
  reviews          Review[]
  priceHistory     ProductPriceHistory[]
  campaignProducts CampaignProduct[]

  @@fulltext([name])
  @@map("products")
}

// ============================================================================
// PRODUCT VARIANTS & IMAGES
// ============================================================================

/// Biến thể sản phẩm - quản lý SKU, size/màu, tồn kho
model ProductVariant {
  id             String  @id @default(uuid()) @db.VarChar(36)
  productId      String  @map("product_id") @db.VarChar(36)
  sku            String  @unique @db.VarChar(100)
  /// Thuộc tính biến thể: {"color": "đỏ", "size": "M"}
  attributes     Json    @default("{}")
  price          Decimal @db.Decimal(10, 2)
  stockAvailable Int     @default(0) @map("stock_available")
  stockReserved  Int     @default(0) @map("stock_reserved")
  minStock       Int     @default(5) @map("min_stock")
  isDeleted      Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  images        ProductImage[]
  inventoryLogs InventoryLog[]
  priceHistory  ProductPriceHistory[]

  @@index([productId])
  @@map("product_variants")
}

/// Ảnh sản phẩm - ảnh chung hoặc riêng cho từng variant
model ProductImage {
  id        String  @id @default(uuid()) @db.VarChar(36)
  productId String  @map("product_id") @db.VarChar(36)
  variantId String? @map("variant_id") @db.VarChar(36)
  url       String  @db.VarChar(1000)
  altText   String? @map("alt_text") @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("product_images")
}

// ============================================================================
// CATEGORIES & TAGS
// ============================================================================

/// Danh mục sản phẩm - hỗ trợ cây phân cấp đa cấp
model Category {
  id          String  @id @default(uuid()) @db.VarChar(36)
  name        String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(255)
  description String? @db.Text
  imageUrl    String? @map("image_url") @db.VarChar(1000)
  parentId    String? @map("parent_id") @db.VarChar(36)
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  parent   Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]        @relation("CategoryTree")
  products ProductCategory[]

  @@index([parentId])
  @@map("categories")
}

/// Bảng trung gian - sản phẩm thuộc nhiều danh mục
model ProductCategory {
  productId  String @map("product_id") @db.VarChar(36)
  categoryId String @map("category_id") @db.VarChar(36)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

/// Tag - nhãn tự do gắn vào sản phẩm
model Tag {
  id   String @id @default(uuid()) @db.VarChar(36)
  name String @unique @db.VarChar(100)
  slug String @unique @db.VarChar(100)

  products ProductTag[]

  @@map("tags")
}

/// Bảng trung gian - sản phẩm gắn nhiều tag
model ProductTag {
  productId String @map("product_id") @db.VarChar(36)
  tagId     String @map("tag_id") @db.VarChar(36)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

// ============================================================================
// CART
// ============================================================================

/// Giỏ hàng - mỗi user có 1 giỏ hàng
model Cart {
  id     String @id @default(uuid()) @db.VarChar(36)
  userId String @unique @map("user_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

/// Chi tiết giỏ hàng
model CartItem {
  id        String  @id @default(uuid()) @db.VarChar(36)
  cartId    String  @map("cart_id") @db.VarChar(36)
  productId String  @map("product_id") @db.VarChar(36)
  variantId String? @map("variant_id") @db.VarChar(36)
  quantity  Int

  // Relations
  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  /// Nếu variantId IS NULL, MySQL cho phép trùng (cartId, productId, NULL) → app phải enforce
  @@unique([cartId, productId, variantId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

// ============================================================================
// ORDERS
// ============================================================================

/// Đơn hàng
model Order {
  id             String      @id @default(uuid()) @db.VarChar(36)
  userId         String      @map("user_id") @db.VarChar(36)
  totalPrice     Decimal     @map("total_price") @db.Decimal(10, 2)
  status         OrderStatus @default(PENDING)
  discountId     String?     @map("discount_id") @db.VarChar(36)
  discountAmount Decimal?    @map("discount_amount") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user          User                 @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payment       Payment?
  statusHistory OrderStatusHistory[]
  invoice       Invoice?
  discount      Discount?            @relation(fields: [discountId], references: [id])
  discountUsage DiscountUsage?

  @@index([status])
  @@index([userId])
  @@map("orders")
}

/// Chi tiết đơn hàng
model OrderItem {
  id        String  @id @default(uuid()) @db.VarChar(36)
  orderId   String  @map("order_id") @db.VarChar(36)
  productId String  @map("product_id") @db.VarChar(36)
  variantId String? @map("variant_id") @db.VarChar(36)
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  // Relations
  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  returns Return[]

  @@unique([orderId, productId, variantId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

// ============================================================================
// PAYMENT (1 order = 1 payment chính)
// ============================================================================

/// Thanh toán - 1:1 với đơn hàng
model Payment {
  id            String        @id @default(uuid()) @db.VarChar(36)
  orderId       String        @unique @map("order_id") @db.VarChar(36)
  amount        Decimal       @db.Decimal(10, 2)
  method        String        @db.VarChar(50)
  transactionId String?       @unique @map("transaction_id") @db.VarChar(255)
  status        PaymentStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at")
  paidAt    DateTime? @map("paid_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================================================
// PRICING HISTORY
// ============================================================================

/// Lịch sử thay đổi giá - phục vụ analytics và audit
model ProductPriceHistory {
  id        String   @id @default(uuid()) @db.VarChar(36)
  productId String   @map("product_id") @db.VarChar(36)
  variantId String?  @map("variant_id") @db.VarChar(36)
  oldPrice  Decimal  @map("old_price") @db.Decimal(10, 2)
  newPrice  Decimal  @map("new_price") @db.Decimal(10, 2)
  changedBy String?  @map("changed_by") @db.VarChar(36)

  changedAt DateTime @default(now()) @map("changed_at")

  // Relations
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@map("product_price_history")
}

// ============================================================================
// PROMOTIONS
// ============================================================================

/// Mã giảm giá
model Discount {
  id             String       @id @default(uuid()) @db.VarChar(36)
  code           String       @unique @db.VarChar(50)
  description    String?      @db.VarChar(500)
  type           DiscountType
  value          Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal?     @map("min_order_amount") @db.Decimal(10, 2)
  maxUsage       Int?         @map("max_usage")
  usedCount      Int          @default(0) @map("used_count")
  startAt        DateTime     @map("start_at")
  endAt          DateTime     @map("end_at")
  isActive       Boolean      @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  usages    DiscountUsage[]
  campaigns CampaignDiscount[]
  orders    Order[]

  @@map("discounts")
}

/// Lịch sử sử dụng mã giảm giá
model DiscountUsage {
  id         String   @id @default(uuid()) @db.VarChar(36)
  discountId String   @map("discount_id") @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  orderId    String   @unique @map("order_id") @db.VarChar(36)

  usedAt DateTime @default(now()) @map("used_at")

  // Relations
  discount Discount @relation(fields: [discountId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([discountId])
  @@index([userId])
  @@map("discount_usages")
}

/// Chiến dịch khuyến mãi - nhóm sản phẩm giảm giá theo thời gian
model Campaign {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  isActive    Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  products  CampaignProduct[]
  discounts CampaignDiscount[]

  @@map("campaigns")
}

/// Sản phẩm tham gia chiến dịch khuyến mãi
model CampaignProduct {
  campaignId      String  @map("campaign_id") @db.VarChar(36)
  productId       String  @map("product_id") @db.VarChar(36)
  /// % giảm riêng cho sản phẩm trong chiến dịch (0.00 - 100.00)
  discountPercent Decimal @map("discount_percent") @db.Decimal(5, 2)

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([campaignId, productId])
  @@map("campaign_products")
}

/// Mã giảm giá áp dụng trong chiến dịch
model CampaignDiscount {
  campaignId String @map("campaign_id") @db.VarChar(36)
  discountId String @map("discount_id") @db.VarChar(36)

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@id([campaignId, discountId])
  @@map("campaign_discounts")
}

// ============================================================================
// INVENTORY LOG (Audit kho hàng)
// ============================================================================

/// Lịch sử nhập/xuất kho - theo dõi ở cấpđộ variant
model InventoryLog {
  id          String          @id @default(uuid()) @db.VarChar(36)
  variantId   String          @map("variant_id") @db.VarChar(36)
  action      InventoryAction
  quantity    Int
  referenceId String?         @map("reference_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId])
  @@map("inventory_logs")
}

// ============================================================================
// RETURNS (Đúng cấp order_item)
// ============================================================================

/// Yêu cầu trả hàng - liên kết với từng order_item
model Return {
  id          String       @id @default(uuid()) @db.VarChar(36)
  orderItemId String       @map("order_item_id") @db.VarChar(36)
  quantity    Int
  reason      String?      @db.Text
  status      ReturnStatus @default(REQUESTED)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([orderItemId])
  @@map("returns")
}

// ============================================================================
// ORDER STATUS HISTORY
// ============================================================================

/// Lịch sử thay đổi trạng thái đơn hàng
model OrderStatusHistory {
  id        String       @id @default(uuid()) @db.VarChar(36)
  orderId   String       @map("order_id") @db.VarChar(36)
  oldStatus OrderStatus? @map("old_status")
  newStatus OrderStatus  @map("new_status")
  changedBy String?      @map("changed_by") @db.VarChar(36)

  changedAt DateTime @default(now()) @map("changed_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

/// Thông báo cho người dùng
model Notification {
  id      String  @id @default(uuid()) @db.VarChar(36)
  userId  String  @map("user_id") @db.VarChar(36)
  content String  @db.Text
  isRead  Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// ============================================================================
// USER ACTIVITY LOG (Phân tích hành vi)
// ============================================================================

/// Lịch sử hoạt động người dùng - phục vụ phân tích AI
model UserActivityLog {
  id       String  @id @default(uuid()) @db.VarChar(36)
  userId   String? @map("user_id") @db.VarChar(36)
  action   String  @db.VarChar(255)
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_activity_logs")
}

// ============================================================================
// WISHLIST
// ============================================================================

/// Danh sách yêu thích
model Wishlist {
  id        String @id @default(uuid()) @db.VarChar(36)
  userId    String @map("user_id") @db.VarChar(36)
  productId String @map("product_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@map("wishlists")
}

// ============================================================================
// REVIEWS
// ============================================================================

/// Đánh giá sản phẩm - mỗi user chỉ đánh giá 1 lần/sản phẩm
model Review {
  id        String  @id @default(uuid()) @db.VarChar(36)
  userId    String  @map("user_id") @db.VarChar(36)
  productId String  @map("product_id") @db.VarChar(36)
  rating    Int // 1-5
  comment   String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

// ============================================================================
// INVOICES
// ============================================================================

/// Hóa đơn - 1:1 với đơn hàng
model Invoice {
  id            String  @id @default(uuid()) @db.VarChar(36)
  orderId       String  @unique @map("order_id") @db.VarChar(36)
  invoiceNumber String  @unique @map("invoice_number") @db.VarChar(50)
  totalAmount   Decimal @map("total_amount") @db.Decimal(10, 2)

  issuedAt DateTime @default(now()) @map("issued_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id])

  @@map("invoices")
}

// ============================================================================
// AUDIT LOG (Chuẩn compliance)
// ============================================================================

/// Nhật ký kiểm toán - theo dõi mọi thay đổi trong hệ thống
model AuditLog {
  id         String    @id @default(uuid()) @db.VarChar(36)
  actorType  ActorType @map("actor_type")
  actorId    String?   @map("actor_id") @db.VarChar(36)
  targetType String?   @map("target_type") @db.VarChar(100)
  targetId   String?   @map("target_id") @db.VarChar(36)
  action     String    @db.VarChar(255)
  oldData    Json?     @map("old_data")
  newData    Json?     @map("new_data")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@map("audit_logs")
}